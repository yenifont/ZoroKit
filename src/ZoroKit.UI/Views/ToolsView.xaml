<UserControl x:Class="ZoroKit.UI.Views.ToolsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
        <StackPanel Margin="24,20,24,24">
            <!-- Page Header -->
            <StackPanel Margin="0,0,0,0">
                <TextBlock Text="Ara&#231;lar" Style="{StaticResource PageTitleStyle}" />
                <TextBlock Text="Veritaban&#305; ara&#231;lar&#305;, yap&#305;land&#305;rma dosyalar&#305; ve MariaDB ayarlar&#305;" Style="{StaticResource PageSubtitleStyle}" />
            </StackPanel>

            <!-- Database Tools -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <DockPanel Margin="0,0,0,12">
                        <materialDesign:PackIcon Kind="DatabaseCog" Width="16" Height="16"
                                                 Foreground="#EA580C" Margin="0,0,8,0"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Veritaban&#305; Ara&#231;lar&#305;" Style="{StaticResource SectionHeaderStyle}" Margin="0" VerticalAlignment="Center" />
                    </DockPanel>
                    <UniformGrid Columns="3">
                        <Button Style="{StaticResource SuccessButtonStyle}" Margin="0,0,3,0"
                                Command="{Binding CreateDatabaseCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                                HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="DatabasePlus" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center" />
                                <TextBlock Text="Olu&#351;tur" VerticalAlignment="Center" FontSize="12" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource GhostButtonStyle}" Margin="3,0,3,0"
                                Command="{Binding ImportDatabaseCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                                HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="DatabaseImport" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center" />
                                <TextBlock Text="&#304;&#231;e Aktar" VerticalAlignment="Center" FontSize="12" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource GhostButtonStyle}" Margin="3,0,0,0"
                                Command="{Binding BackupDatabaseCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                                HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="DatabaseExport" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center" />
                                <TextBlock Text="Yedekle" VerticalAlignment="Center" FontSize="12" />
                            </StackPanel>
                        </Button>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- Config Files -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <DockPanel Margin="0,0,0,12">
                        <materialDesign:PackIcon Kind="FileEditOutline" Width="16" Height="16"
                                                 Foreground="{StaticResource PrimaryBrush}" Margin="0,0,8,0"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Yap&#305;land&#305;rma Dosyalar&#305;" Style="{StaticResource SectionHeaderStyle}" Margin="0" VerticalAlignment="Center" />
                    </DockPanel>
                    <UniformGrid Columns="3">
                        <Button Style="{StaticResource GhostButtonStyle}" Command="{Binding OpenApacheConfigCommand}"
                                Margin="0,0,4,0" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="Server" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center" />
                                <TextBlock Text="httpd.conf" VerticalAlignment="Center" FontSize="12" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource GhostButtonStyle}" Command="{Binding OpenPhpIniCommand}"
                                Margin="2,0,2,0" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="LanguagePhp" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center" />
                                <TextBlock Text="php.ini" VerticalAlignment="Center" FontSize="12" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource GhostButtonStyle}" Command="{Binding OpenMariaDbConfigCommand}"
                                Margin="4,0,0,0" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="Database" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center" />
                                <TextBlock Text="my.ini" VerticalAlignment="Center" FontSize="12" />
                            </StackPanel>
                        </Button>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- MariaDB Settings -->
            <Border Style="{StaticResource CardStyle}" Padding="14,12">
                <StackPanel>
                    <DockPanel Margin="0,0,0,10">
                        <materialDesign:PackIcon Kind="DatabaseCog" Width="15" Height="15"
                                                 Foreground="#EA580C" Margin="0,0,8,0"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="MariaDB Ayarlar&#305;" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}" VerticalAlignment="Center" />
                        <Button DockPanel.Dock="Right" HorizontalAlignment="Right"
                                Command="{Binding SaveMariaDbSettingsCommand}" Cursor="Hand"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                                Background="Transparent" BorderThickness="0" Padding="0">
                            <TextBlock Text="Kaydet" FontSize="11.5" FontWeight="Medium"
                                       Foreground="{StaticResource PrimaryBrush}" />
                        </Button>
                    </DockPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="innodb_buffer_pool_size" FontSize="10"
                                       Foreground="{StaticResource MutedTextBrush}" Margin="2,0,0,3" />
                            <Grid>
                                <TextBox Text="{Binding MariaDbInnodbBufferPoolSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputTextBoxStyle}" FontSize="11.5"
                                         Padding="8,5,26,5" BorderThickness="0" />
                                <materialDesign:PackIcon Kind="InformationOutline" Width="12" Height="12"
                                                         Foreground="{StaticResource MutedTextBrush}" Cursor="Help"
                                                         HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,7,0"
                                                         ToolTip="InnoDB i&#231;in ayr&#305;lan bellek havuz boyutu." />
                            </Grid>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="max_connections" FontSize="10"
                                       Foreground="{StaticResource MutedTextBrush}" Margin="2,0,0,3" />
                            <Grid>
                                <TextBox Text="{Binding MariaDbMaxConnections, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputTextBoxStyle}" FontSize="11.5"
                                         Padding="8,5,26,5" BorderThickness="0" />
                                <materialDesign:PackIcon Kind="InformationOutline" Width="12" Height="12"
                                                         Foreground="{StaticResource MutedTextBrush}" Cursor="Help"
                                                         HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,7,0"
                                                         ToolTip="Maksimum e&#351; zamanl&#305; ba&#287;lant&#305; say&#305;s&#305;." />
                            </Grid>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="max_allowed_packet" FontSize="10"
                                       Foreground="{StaticResource MutedTextBrush}" Margin="2,0,0,3" />
                            <Grid>
                                <TextBox Text="{Binding MariaDbMaxAllowedPacket, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputTextBoxStyle}" FontSize="11.5"
                                         Padding="8,5,26,5" BorderThickness="0" />
                                <materialDesign:PackIcon Kind="InformationOutline" Width="12" Height="12"
                                                         Foreground="{StaticResource MutedTextBrush}" Cursor="Help"
                                                         HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,7,0"
                                                         ToolTip="Tek pakette g&#246;nderilebilecek maksimum veri boyutu." />
                            </Grid>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Status -->
            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource StatusTextStyle}" Margin="0,8,0,0" FontSize="11" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
